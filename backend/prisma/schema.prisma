// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// ====================== ENUMS ========================
// =====================================================

enum Role {
  USER
  ADMIN
  FOUNDER
}

enum LicenseType {
  TRIAL
  THREE_DAYS
  SEVEN_DAYS
  FIFTEEN_DAYS
  THIRTY_DAYS
  FOUNDER
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum RoomType {
  GA          // General Access (gratuita)
  AP          // Access Pass (pago)
}

enum BotStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// =====================================================
// ====================== MODELS =======================
// =====================================================

model User {
  id          String   @id @default(cuid())
  discordId   String   @unique
  username    String
  avatar      String?
  email       String?
  roles       Role[]   @default([USER])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  licenses          License[]
  rooms             Room[]
  imvuAccount       IMVUAccount?
  botInstallations  BotInstallation[]
  bans              Ban[]
}

model License {
  id        String         @id @default(cuid())
  userId    String
  type      LicenseType
  status    LicenseStatus  @default(ACTIVE)
  code      String         @unique
  maxRooms  Int            @default(3)
  expiresAt DateTime
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Room {
  id          String    @id @default(cuid())
  userId      String
  name        String
  imvuRoomId  String    @unique
  url         String
  roomType    RoomType  @default(GA)      // GA o AP
  createdAt   DateTime  @default(now())

  user              User               @relation(fields: [userId], references: [id])
  botInstallation   BotInstallation?
  musicProfile      RoomMusicProfile?
  playlists         Playlist[]
  queueTracks       QueueTrack[]
  playHistory       PlayHistory[]
}

model BotInstallation {
  id        String     @id @default(cuid())
  roomId    String     @unique
  code      String     @unique
  status    BotStatus  @default(ACTIVE)
  createdAt DateTime   @default(now())

  room Room @relation(fields: [roomId], references: [id])
}

model IMVUAccount {
  id        String   @id @default(cuid())
  userId    String   @unique
  username  String
  roomId    String
  roomUrl   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model RoomMusicProfile {
  id             String   @id @default(cuid())
  roomId         String   @unique
  favoriteGenres String[]
  skippedTracks  String[]
  playedTracks   String[]
  lastActiveAt   DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id])
}

model Playlist {
  id          String   @id @default(cuid())
  roomId      String
  name        String
  description String?
  createdAt   DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id])
}

// =====================================================
// ============== COLA Y REPRODUCCIÓN ==================
// =====================================================

model QueueTrack {
  id        String   @id @default(cuid())
  roomId    String
  title     String
  url       String?
  addedBy   String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id])
}

model PlayHistory {
  id        String   @id @default(cuid())
  roomId    String
  title     String
  url       String?
  playedAt  DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id])
}

// =====================================================
// ==================== MODERACIÓN =====================
// =====================================================

model Ban {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  username  String
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
