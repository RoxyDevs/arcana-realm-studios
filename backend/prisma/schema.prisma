generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FOUNDER
  ADMIN
  PARTNER
  PREMIUM
  TRIAL
  USER
}

enum LicenseType {
  FOUNDER
  TRIAL
  THREE_DAYS
  SEVEN_DAYS
  FIFTEEN_DAYS
  THIRTY_DAYS
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  PENDING
}

model User {
  id             String    @id @default(cuid())
  discordId      String    @unique
  username       String
  avatar         String?
  email          String?   @unique
  roles          Role[]    @default([USER])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  licenses       License[]
  imvuAccount    IMVUAccount?
  rooms          Room[]
  payments       Payment[]
  referrals      Referral[]
  auditEvents    AuditEvent[]
}

model License {
  id          String        @id @default(cuid())
  type        LicenseType
  status      LicenseStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  expiresAt   DateTime
  code        String        @unique
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  maxRooms    Int           @default(1)
  maxPlaylists Int          @default(10)
}

model IMVUAccount {
  id          String   @id @default(cuid())
  username    String
  roomId      String
  roomUrl     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @unique
}

model Room {
  id                 String             @id @default(cuid())
  name               String
  imvuRoomId         String
  url                String
  active             Boolean            @default(true)
  autoDjEnabled      Boolean            @default(false)
  owner              User               @relation(fields: [userId], references: [id])
  userId             String
  playlists          Playlist[]
  musicProfile       RoomMusicProfile?
  botInstallations   BotInstallation[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Playlist {
  id          String         @id @default(cuid())
  name        String
  description String?
  room        Room           @relation(fields: [roomId], references: [id])
  roomId      String
  items       PlaylistItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlist   Playlist @relation(fields: [playlistId], references: [id])
  playlistId String
  title      String
  artist     String?
  genre      String?
  bpm        Int?
  metadata   Json?
  order      Int      @default(0)
}

model RoomMusicProfile {
  id             String   @id @default(cuid())
  room           Room     @relation(fields: [roomId], references: [id])
  roomId         String   @unique
  favoriteGenres String[] @default([])
  skippedTracks  String[] @default([])
  playedTracks   String[] @default([])
  moodHistory    Json?    
  lastActiveAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BotInstallation {
  id          String   @id @default(cuid())
  code        String   @unique
  room        Room     @relation(fields: [roomId], references: [id])
  roomId      String
  installedAt DateTime @default(now())
  status      String   @default("ACTIVE")
}

model Referral {
  id         String   @id @default(cuid())
  code       String   @unique
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  sales      Int      @default(0)
  commission Float    @default(0.0)
  createdAt  DateTime @default(now())
}

model Payment {
  id           String    @id @default(cuid())
  provider     String
  providerId   String    @unique
  status       String
  amount       Float
  currency     String
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  createdAt    DateTime  @default(now())
}

model AuditEvent {
  id        String   @id @default(cuid())
  type      String
  payload   Json?
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  createdAt DateTime @default(now())
}
